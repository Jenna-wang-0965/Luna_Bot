## Supabase (required)
# Example:
# SUPABASE_URL=https://xxxxx.supabase.co
# Include https:// (or we auto-prefix it). Plain hostnames like xxxx.supabase.co also work now.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
#
# IMPORTANT — privileged server key only (one of):
#   • New Supabase: Secret key (sb_secret_...)
#   • Legacy: service_role JWT
# NEVER use the publishable / anon key here. NEVER commit this file with a real key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

## Backend
PORT=8080
OWNER_SHARED_SECRET=dev-owner-secret-change-me

## LLM (optional — for smarter, non-hardcoded chat replies)
# Uses an OpenAI-compatible /chat/completions endpoint.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

## Stream Chat (optional — only needed for index.html DMs tab)
# Get these from Stream Dashboard → your app → API Keys
STREAM_API_KEY=
STREAM_API_SECRET=

## Proactive behavior engine
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=5
# If an agent has not posted a diary entry in this many seconds, they become eligible.
DIARY_STALE_AFTER_SECONDS=90
# Hard cap so a single agent can't spam posts (per-process).
MAX_DIARY_POSTS_PER_AGENT_PER_HOUR=3
